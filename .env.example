# Kalshi API credentials
# Get your API key ID from: https://kalshi.com/profile/api
KALSHI_API_KEY_ID=your-api-key-id-here
# Path to your RSA private key .pem file (generated alongside your API key)
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Strategy parameters
MIN_EDGE=0.08                  # Minimum edge (0-1) required to place a trade
MIN_T_HOURS=0.5                # Skip markets expiring in fewer than this many hours

# Risk parameters
MAX_DAILY_SPEND=100            # Hard cap on total cost basis spent per calendar day (USD)
MAX_CONTRACTS_PER_MARKET=10   # Max contracts to buy in a single market
MAX_POSITIONS=5                # Max concurrent open Kalshi positions
KELLY_FRACTION=0.25            # Fraction of full Kelly to use (0.25 = conservative)

# Execution
POLL_INTERVAL_SECONDS=300      # How often the main loop runs (default: 5 min)
DRY_RUN=false                  # Set to true to log signals without placing real orders
