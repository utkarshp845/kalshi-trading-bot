# Kalshi API credentials
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./bitcoin-key.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Strategy
MIN_EDGE=0.08
MIN_T_HOURS=0.5

# Risk
MAX_DAILY_SPEND=100
MAX_CONTRACTS_PER_MARKET=10
MAX_POSITIONS=5
KELLY_FRACTION=0.25

# Execution
POLL_INTERVAL_SECONDS=300
DRY_RUN=false
FORCE_TRADING_HOURS=false

# Kalshi taker fee in dollars per contract (check your account tier)
KALSHI_TAKER_FEE=0.07

# Volatility lookback windows (days)
VOL_SHORT_DAYS=7
VOL_LONG_DAYS=30
