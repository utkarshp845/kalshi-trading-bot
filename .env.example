# Kalshi API credentials
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./bitcoin-key.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Strategy
TRADING_MODE=observe
MIN_EDGE=0.15
MIN_T_HOURS=1.0
VOL_SAFETY_MARGIN=1.25
MAX_VOL_RATIO=1.8
MAX_BID_ASK_SPREAD=0.25
MAX_BID_ASK_PCT_SPREAD=0.30
MAX_LAST_PRICE_DIVERGENCE=0.15
THEO_PROB_BAND_MIN=0.15
THEO_PROB_BAND_MAX=0.85
MAX_SIGMA_DISTANCE=1.5
MAX_CHAIN_BREAK_PCT=0.10
EDGE_LEAK_LOOKBACK_FILLS=50
EDGE_HURDLE_BUFFER=0.02
SETTLED_MAE_LOOKBACK_TRADES=30
DEFAULT_EXPECTED_SLIPPAGE=0.03
DEFAULT_UNCERTAINTY_PENALTY=0.05
DATA_STALE_AFTER_SEC_KRAKEN=20
DATA_STALE_AFTER_SEC_KALSHI=20
DATA_STALE_AFTER_SEC_DERIBIT=120
LIVE_MIN_REQUIRED_EDGE=0.25
COLD_START_MIN_EDGE=0.30
LIVE_MIN_FILL_HISTORY=15
LIVE_MIN_SETTLED_HISTORY=10
LIVE_GUARD_LOOKBACK_FILLS=20
LIVE_GUARD_LOOKBACK_SETTLED=20
LIVE_HALT_MAX_AVG_REALIZED_EDGE=0.0
LIVE_HALT_MAX_SETTLED_MAE=0.20
LIVE_SKIP_DEGRADED_ASSETS=true

# Risk
MAX_DAILY_SPEND=5
MAX_CONTRACTS_PER_MARKET=3
MAX_POSITIONS=2
MAX_SYMBOL_DAILY_SPEND_PCT=0.05
MAX_SYMBOL_POSITIONS=1
KELLY_FRACTION=0.10
MAX_DRAWDOWN_PCT=0.20
BANKROLL_FRACTION=0.25

# Implied vol calibration
IV_CALIBRATION_MIN_OBS=10
IV_SAFETY_MARGIN_MIN=1.05
IV_SAFETY_MARGIN_MAX=3.0

# Position exit
ENABLE_POSITION_EXIT=true
EXIT_LOSS_TRIGGER=0.40

# Smart order placement (mid-price with ask fallback)
ENABLE_PRICE_IMPROVEMENT=true
PRICE_IMPROVEMENT_TIMEOUT_SEC=45

# Monitoring (Slack/Discord webhook; leave empty for log-only)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_MIN_LEVEL=WARNING
ALERT_DEDUP_SECONDS=900

# Execution
POLL_INTERVAL_SECONDS=120
DRY_RUN=false
FORCE_TRADING_HOURS=false

# Kalshi taker fee in dollars per contract (check your account tier)
KALSHI_TAKER_FEE=0.07

# Volatility lookback windows (days)
VOL_SHORT_DAYS=7
VOL_LONG_DAYS=30
