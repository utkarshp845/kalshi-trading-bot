# Kalshi API credentials
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./bitcoin-key.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Strategy
MIN_EDGE=0.15
MIN_T_HOURS=1.0
VOL_SAFETY_MARGIN=1.25
MAX_VOL_RATIO=1.8
MAX_BID_ASK_SPREAD=0.25
MAX_BID_ASK_PCT_SPREAD=0.30
MAX_LAST_PRICE_DIVERGENCE=0.15

# Risk
MAX_DAILY_SPEND=5
MAX_CONTRACTS_PER_MARKET=3
MAX_POSITIONS=2
KELLY_FRACTION=0.10
MAX_DRAWDOWN_PCT=0.20
BANKROLL_FRACTION=0.25

# Implied vol calibration
IV_CALIBRATION_MIN_OBS=10
IV_SAFETY_MARGIN_MIN=1.05
IV_SAFETY_MARGIN_MAX=3.0

# Position exit
ENABLE_POSITION_EXIT=true
EXIT_LOSS_TRIGGER=0.40

# Smart order placement (mid-price with ask fallback)
ENABLE_PRICE_IMPROVEMENT=true
PRICE_IMPROVEMENT_TIMEOUT_SEC=45

# Monitoring (Slack/Discord webhook; leave empty for log-only)
ALERT_WEBHOOK_URL=

# Execution
POLL_INTERVAL_SECONDS=120
DRY_RUN=false
FORCE_TRADING_HOURS=false

# Kalshi taker fee in dollars per contract (check your account tier)
KALSHI_TAKER_FEE=0.07

# Volatility lookback windows (days)
VOL_SHORT_DAYS=7
VOL_LONG_DAYS=30
